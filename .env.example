# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here
PORT=8080

# Fax sending (/api/send-fax). Options: dryrun | documo | notifyre
# "dryrun" writes the PDF to ./outbox/ instead of faxing -- safe for testing.
# For real providers, set FAX_API_KEY from your provider dashboard.
FAX_PROVIDER=dryrun
FAX_API_KEY=
