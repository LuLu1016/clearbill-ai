# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here
PORT=8080

# Fax sending (/api/send-fax). Options: dryrun | documo | notifyre
# "dryrun" writes the PDF to ./outbox/ instead of faxing -- safe for testing.
# For real providers, set FAX_API_KEY from your provider dashboard.
FAX_PROVIDER=dryrun
FAX_API_KEY=

# CMS NCCI reference files for the unbundling/MUE checks. Download them
# yourself (AMA copyright click-through -- see STEP_BY_STEP_PLAN.md Step 2
# and data/raw/README.md), drop them in data/raw/ (gitignored), and point
# these at whatever CMS named your download. Files absent = checks are
# silently skipped; everything else still works.
PTP_EDITS_PATH=data/raw/ccioph-v322r0-f1.txt
MUE_TABLE_PATH=data/raw/MCR_MUE_OutpatientHospitalServices_Eff_07-01-2026.csv
